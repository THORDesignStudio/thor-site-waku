{
  "name": "thor-site-waku",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "waku dev",
    "build": "npm run generate:redirects && waku build",
    "start": "waku start",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "generate:redirects": "node --import=tsx scripts/generate-redirects.ts"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "gsap": "^3.14.2",
    "jotai": "^2.18.1",
    "lenis": "^1.3.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-server-dom-webpack": "19.2.4",
    "vaul": "^1.1.2",
    "waku": "1.0.0-alpha.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "prettier": "^3.8.1",
    "tailwindcss": "4.1.18",
    "tsx": "^4.0.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "minimatch": "^10.2.3"
  }
}
